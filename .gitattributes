###############################################################################
# Git configuration files
###############################################################################
.gitattributes text eol=lf
.gitignore text eol=lf
.gitmodules text eol=lf

###############################################################################
# Set merge driver for project and solution files
###############################################################################
*.sln merge=union
*.vcxproj merge=union
*.vcxproj.filters merge=union
*.vcproj merge=union
