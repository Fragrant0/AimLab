*.7z binary
*.tar binary
*.gz binary
*.bz2 binary
*.xz binary

###############################################################################
# Executable and library files - binary
###############################################################################
*.exe binary
*.dll binary
*.so binary
*.a binary
*.lib binary
*.o binary
*.obj binary
*.pyd binary

###############################################################################
# Font files - binary
###############################################################################
*.ttf binary
*.otf binary
