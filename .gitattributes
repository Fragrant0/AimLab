###############################################################################
# Set default behavior to automatically normalize line endings.
###############################################################################
* text=auto eol=lf

###############################################################################
# C/C++ source files - use LF line endings
###############################################################################
*.c text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf
*.cc text eol=lf
*.cxx text eol=lf
*.hxx text eol=lf
*.inl text eol=lf

###############################################################################
# Shader files - use LF line endings
###############################################################################
*.vs text eol=lf
*.fs text eol=lf
*.gs text eol=lf
*.tesc text eol=lf
*.tese text eol=lf
*.comp text eol=lf
*.glsl text eol=lf
*.vert text eol=lf
*.frag text eol=lf
*.geom text eol=lf

###############################################################################
# Configuration and data files
###############################################################################
*.json text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.txt text eol=lf
*.md text eol=lf

###############################################################################
# Build system files
###############################################################################
*.sln text eol=crlf
*.vcxproj text eol=crlf
*.vcxproj.filters text eol=crlf
*.vcxproj.user text eol=crlf
*.csproj text eol=crlf
*.proj text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf
CMakeLists.txt text eol=lf
*.cmake text eol=lf

###############################################################################
# Script files
###############################################################################
*.sh text eol=lf
*.bash text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

###############################################################################
# Image files - binary
###############################################################################
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.tga binary
*.tiff binary
*.ico binary
*.webp binary
*.svg binary

###############################################################################
